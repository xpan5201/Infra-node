#!/usr/bin/env bash
set -Eeuo pipefail

INFRA_ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." && pwd -P)"
# shellcheck disable=SC1091
source "$INFRA_ROOT/config/defaults.env"
INFRA_VERSION="$(tr -d '\r\n' <"$INFRA_ROOT/VERSION")"
for _lib in ui core platform packages transaction updater; do source "$INFRA_ROOT/lib/${_lib}.sh"; done
for _module in assessment base network proxy firewall audit experience deploy; do source "$INFRA_ROOT/lib/modules/${_module}.sh"; done
source "$INFRA_ROOT/lib/tui.sh"

usage() {
  cat <<'EOF_USAGE'
Infra-node — 代理节点主机基础设施工具（不部署代理服务）

用法:
  infra-node [全局选项] <命令> [参数]

全局选项:
  --yes                自动确认安全提示
  --non-interactive    禁止交互
  --dry-run            显示部分系统操作但不执行
  --no-color           禁用颜色

命令:
  deploy [选项]        部署基础设施
  status               查看状态
  check                运行诊断与审计
  doctor               环境诊断
  audit                安全审计
  panel                交互面板
  firewall configure  交互配置并启用/更新自有 nftables 表
  firewall show       查看自有 nftables 表；未启用时友好提示
  firewall disable    删除自有 nftables 表
  firewall enable     configure 的兼容别名
  firewall status     show 的兼容别名
  experience [URL]     按需 HTTPS 网络测试
  backup list          列出事务备份
  backup restore ID    恢复指定事务
  self-update [REF] [完整 SHA]
  version
  help

deploy 选项:
  --profile auto|minimal|balanced|performance
  --swap auto|yes|no
  --security-updates yes|no
  --proxy-units auto|unit1.service,unit2.service
  --restart-proxy yes|no   默认 no

firewall configure/enable 选项:
  --tcp 80,443         额外允许 TCP 端口或范围；SSH 监听端口自动保留
  --udp 443,20000-20100
EOF_USAGE
}

parse_global_options() {
  REMAINING_ARGS=()
  while (($#)); do
    case "$1" in
      --yes|-y) INFRA_ASSUME_YES=1 ;;
      --non-interactive) INFRA_NON_INTERACTIVE=1 ;;
      --dry-run) INFRA_DRY_RUN=1 ;;
      --no-color) INFRA_NO_COLOR=1 ;;
      --verbose) INFRA_VERBOSE=1 ;;
      --) shift; REMAINING_ARGS+=("$@"); break ;;
      *) REMAINING_ARGS+=("$1") ;;
    esac
    shift
  done
}

cmd_deploy_parse() {
  local profile=auto swap=auto updates=no units=auto restart=no
  while (($#)); do
    case "$1" in
      --profile) if [[ $# -lt 2 ]]; then core_die '--profile 缺少值'; return 1; fi; profile="$2"; shift 2 ;;
      --swap) if [[ $# -lt 2 ]]; then core_die '--swap 缺少值'; return 1; fi; swap="$2"; shift 2 ;;
      --security-updates) if [[ $# -lt 2 ]]; then core_die '--security-updates 缺少值'; return 1; fi; updates="$2"; shift 2 ;;
      --proxy-units) if [[ $# -lt 2 ]]; then core_die '--proxy-units 缺少值'; return 1; fi; units="$2"; shift 2 ;;
      --restart-proxy) if [[ $# -lt 2 ]]; then core_die '--restart-proxy 缺少值'; return 1; fi; restart="$2"; shift 2 ;;
      *) core_die "deploy 未知参数：$1"; return 1 ;;
    esac
  done
  if [[ $swap != auto && $swap != yes && $swap != no ]]; then core_die '--swap 必须为 auto/yes/no'; return 1; fi
  if [[ $updates != yes && $updates != no ]]; then core_die '--security-updates 必须为 yes/no'; return 1; fi
  if [[ $restart != yes && $restart != no ]]; then core_die '--restart-proxy 必须为 yes/no'; return 1; fi
  deploy_run "$profile" "$swap" "$updates" "$units" "$restart"
}

cmd_firewall_configure_parse() {
  local explicit="${1:-0}" tcp='' udp='' positional=0
  shift || true
  while (($#)); do
    case "$1" in
      --tcp) if [[ $# -lt 2 ]]; then core_die '--tcp 缺少值'; return 1; fi; tcp="$2"; explicit=1; shift 2 ;;
      --udp) if [[ $# -lt 2 ]]; then core_die '--udp 缺少值'; return 1; fi; udp="$2"; explicit=1; shift 2 ;;
      --) shift; break ;;
      -*) core_die "未知防火墙参数：$1"; return 1 ;;
      *)
        positional=$((positional+1)); explicit=1
        case "$positional" in
          1) tcp="$1" ;;
          2) udp="$1" ;;
          *) core_die '防火墙位置参数最多为 TCP 和 UDP 两项。'; return 1 ;;
        esac
        shift
        ;;
    esac
  done
  core_require_root || return
  core_acquire_lock || return
  firewall_configure "$tcp" "$udp" "$explicit" || return
  txn_commit || return
  firewall_finalize
}

cmd_firewall_parse() {
  local action="${1:-show}"
  (($#)) && shift || true
  case "$action" in
    configure|apply) cmd_firewall_configure_parse 0 "$@" ;;
    enable) cmd_firewall_configure_parse 1 "$@" ;;
    show|status)
      if (($# != 0)); then core_die "firewall $action 不接受额外参数。"; return 1; fi
      firewall_show
      ;;
    disable|remove)
      if (($# != 0)); then core_die "firewall $action 不接受额外参数。"; return 1; fi
      core_require_root || return; core_acquire_lock || return
      firewall_disable || return
      txn_commit || return
      firewall_finalize
      ;;
    *) core_die '未知 firewall 子命令；可用：configure|show|disable。'; return 1 ;;
  esac
}

main() {
  parse_global_options "$@"; set -- "${REMAINING_ARGS[@]}"
  ui_detect; core_init "$@"
  local command="${1:-panel}"; (($#)) && shift || true
  case "$command" in
    deploy) cmd_deploy_parse "$@" ;;
    status) status_run ;;
    check) doctor_run; audit_run ;;
    doctor) doctor_run ;;
    audit) audit_run ;;
    panel) tui_panel ;;
    firewall) cmd_firewall_parse "$@" ;;
    experience) experience_run "${1:-$INFRA_TEST_URL}" ;;
    backup)
      case "${1:-list}" in
        list) txn_list ;;
        restore) if [[ -z ${2:-} ]]; then core_die 'backup restore 缺少事务 ID'; return 1; fi; core_acquire_lock || return; txn_restore_id "$2" ;;
        *) core_die '未知 backup 子命令'; return 1 ;;
      esac
      ;;
    self-update) cmd_self_update "${1:-}" "${2:-}" ;;
    version|-V|--version) printf 'Infra-node %s\n' "$INFRA_VERSION" ;;
    help|-h|--help) usage ;;
    *) usage >&2; core_die "未知命令：$command"; return 1 ;;
  esac
}

main "$@"
