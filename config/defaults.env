# Infra-node fixed paths are an installation contract, not user input.
INFRA_INSTALL_DIR=/opt/infra-node
INFRA_COMMAND_DIR=/usr/local/bin
INFRA_ETC_DIR=/etc/infra-node
INFRA_STATE_DIR=/var/lib/infra-node
INFRA_LOG_DIR=/var/log/infra-node
INFRA_BACKUP_DIR=/var/backups/infra-node
INFRA_REPO_URL=https://github.com/xpan5201/Infra-node.git
INFRA_REPO_REF=main
INFRA_GIT_TIMEOUT=90
INFRA_UPDATE_TIMEOUT=20
INFRA_BACKUP_KEEP=5
INFRA_LOG_KEEP=5
INFRA_FIREWALL_ROLLBACK_SECONDS=300
INFRA_TEST_URL=https://www.cloudflare.com/cdn-cgi/trace
INFRA_NO_COLOR=0
INFRA_VERBOSE=0
INFRA_NON_INTERACTIVE=0
INFRA_ASSUME_YES=0
INFRA_DRY_RUN=0
